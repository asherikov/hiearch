digraph horizontal_test {
style=filled;
pad=0.3;
splines=ortho;
nodesep=1.50;
ranksep=1.50;
fontname="Sans-Serif";
fontsize=24;
fontcolor="#2D3436";
compound=true;
mobile_user [shape=none, style=rounded, fontname="Sans-Serif", fontsize=24, fontcolor="#2D3436", margin=0, label=<<table fixedsize="true" width="300" align="center" border="0" cellborder="0" cellspacing="0" cellpadding="0"><tr><td><img src="mobile.png"/></td><td>Mobile User</td></tr></table>>];
cloudfront [shape=none, style=rounded, fontname="Sans-Serif", fontsize=24, fontcolor="#2D3436", margin=0, label=<<table fixedsize="true" width="300" align="center" border="0" cellborder="0" cellspacing="0" cellpadding="0"><tr><td><img src="cloudfront.png"/></td><td>CloudFront<br />CDN</td></tr></table>>];
mobile_user -> cloudfront [color="#7B8894", fontname="Sans-Serif", fontsize=20, fontcolor="#2D3436", arrowsize=1.5, penwidth=2];
}
